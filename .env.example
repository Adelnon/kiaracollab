# Copy to `.env` and fill in real values. Never commit `.env`.

# Discord bot token — from https://discord.com/developers/applications → your app → Bot → Reset Token
DISCORD_TOKEN=

# Anthropic API key — from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Claude model to drive the /task agent. Pick from:
#   claude-opus-4-8       (most capable)
#   claude-sonnet-5       (balanced default)
#   claude-haiku-4-5-20251001  (fast/cheap)
CLAUDE_MODEL=claude-sonnet-5

# Comma-separated Discord user IDs allowed to run /task. Leave empty to allow anyone
# with the "Administrator" permission in the guild.
TASK_ALLOWED_USER_IDS=

# Optional: restrict /task to specific guild IDs (comma-separated). Empty = all guilds.
TASK_ALLOWED_GUILD_IDS=

# Max Claude agent turns per /task invocation (safety cap).
MAX_AGENT_TURNS=12
