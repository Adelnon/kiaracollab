# Discord bot token (Discord Developer Portal -> Bot -> Token)
DISCORD_TOKEN=

# Discord application (client) id (Discord Developer Portal -> General Information -> Application ID)
DISCORD_CLIENT_ID=

# Anthropic API key used to interpret /task requests
ANTHROPIC_API_KEY=

# Discord user id of the bot owner. Only this user can run owner-only actions
# such as creating a brand new guild.
OWNER_ID=

# Optional: channel id where every executed /task action is logged for audit purposes.
MOD_LOG_CHANNEL_ID=
